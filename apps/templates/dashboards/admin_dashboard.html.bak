{% extends 'base.html' %}
{% load static %}
{% block title %}Admin Dashboard – ENABLE PROGRAM{% endblock %}
{% block body %}
<div class="dash-layout">
  <!-- ═══════════ SIDEBAR ═══════════ -->
  <aside class="dash-sidebar">
    <div class="sidebar-brand">
      <span class="logo-icon">E</span>
      <span class="brand-text">ENF Online</span>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">
        <span class="nav-label">MAIN</span>
        <a href="#" class="nav-link active"><i class="fas fa-home"></i> Dashboard</a>
        <a href="#" class="nav-link"><i class="fas fa-chart-pie"></i> Analytics</a>
      </div>

      <div class="nav-section">
        <span class="nav-label">USERS</span>
        <a href="#" class="nav-link"><i class="fas fa-user-graduate"></i> Students</a>
        <a href="#" class="nav-link"><i class="fas fa-chalkboard-teacher"></i> Teachers</a>
        <a href="#" class="nav-link"><i class="fas fa-user-shield"></i> Admins</a>
        <a href="#" class="nav-link"><i class="fas fa-user-lock"></i> Roles &amp; Permissions</a>
      </div>

      <div class="nav-section">
        <span class="nav-label">ACADEMIC</span>
        <a href="#" class="nav-link"><i class="fas fa-layer-group"></i> Batches</a>
        <a href="#" class="nav-link"><i class="fas fa-book"></i> Subjects</a>
        <a href="#" class="nav-link"><i class="fas fa-video"></i> Classes</a>
        <a href="#" class="nav-link"><i class="fas fa-clipboard-list"></i> Tests</a>
      </div>

      <div class="nav-section">
        <span class="nav-label">CONTENT</span>
        <a href="#" class="nav-link"><i class="fab fa-youtube"></i> YouTube</a>
        <a href="#" class="nav-link"><i class="fas fa-book-open"></i> Study Materials</a>
      </div>

      <div class="nav-section">
        <span class="nav-label">SYSTEM</span>
        <a href="#" class="nav-link"><i class="fas fa-building"></i> Tenants</a>
        <a href="#" class="nav-link"><i class="fas fa-cog"></i> Settings</a>
        <a href="#" class="nav-link"><i class="fas fa-clipboard-list"></i> Audit Logs</a>
        <a href="#" class="nav-link"><i class="fas fa-database"></i> Backup</a>
      </div>
    </nav>

    <div class="sidebar-bottom">
      <a href="/admin/" class="nav-link admin-link"><i class="fas fa-tools"></i> Django Admin</a>
      <a href="/logout/" class="nav-link logout-link"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </aside>

  <!-- ═══════════ MAIN AREA ═══════════ -->
  <main class="dash-main">
    <!-- Topbar -->
    <header class="dash-topbar">
      <h1>Admin Dashboard</h1>
      <div class="topbar-right">
        <button class="icon-btn"><i class="fas fa-bell"></i></button>
        <div class="user-avatar">
          <span class="avatar-initials">{{ user_name|truncatechars:2 }}</span>
          <span class="avatar-name">{{ user_name }}</span>
        </div>
      </div>
    </header>

    <!-- Content -->
    <section class="dash-content">
      <!-- Welcome Banner -->
      <div class="welcome-banner">
        <div>
          <h2>Welcome back, {{ user_name }}!</h2>
          <p class="welcome-date">{{ today_date|default:"February 14, 2026" }}</p>
        </div>
      </div>

      <!-- ── Stat Cards ── -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-icon blue"><i class="fas fa-user-graduate"></i></div>
          <div class="stat-info">
            <span class="stat-value">{{ total_students|default:"1" }}</span>
            <span class="stat-label">Total Students</span>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon green"><i class="fas fa-chalkboard-teacher"></i></div>
          <div class="stat-info">
            <span class="stat-value">{{ total_teachers|default:"1" }}</span>
            <span class="stat-label">Total Teachers</span>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon amber"><i class="fas fa-building"></i></div>
          <div class="stat-info">
            <span class="stat-value">{{ total_tenants|default:"1" }}</span>
            <span class="stat-label">Total Tenants</span>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-icon purple"><i class="fas fa-clipboard-list"></i></div>
          <div class="stat-info">
            <span class="stat-value">{{ total_audit|default:"0" }}</span>
            <span class="stat-label">Audit Logs</span>
          </div>
        </div>
      </div>

      <!-- ── System Health ── -->
      <div class="data-card">
        <div class="data-card-header">
          <h3>System Health</h3>
        </div>
        <div class="data-card-body">
          <div class="health-grid">
            <div class="health-item healthy">
              <i class="fas fa-database"></i>
              <span class="health-name">PostgreSQL</span>
              <span class="health-status"><i class="fas fa-check-circle"></i> Active</span>
            </div>
            <div class="health-item healthy">
              <i class="fas fa-server"></i>
              <span class="health-name">Django Server</span>
              <span class="health-status"><i class="fas fa-check-circle"></i> Running</span>
            </div>
            <div class="health-item healthy">
              <i class="fas fa-key"></i>
              <span class="health-name">JWT Auth</span>
              <span class="health-status"><i class="fas fa-check-circle"></i> Active</span>
            </div>
            <div class="health-item healthy">
              <i class="fas fa-clipboard-list"></i>
              <span class="health-name">Audit Logging</span>
              <span class="health-status"><i class="fas fa-check-circle"></i> Active</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Two-Column Grid ── -->
      <div class="content-grid two-col">
        <!-- Recent Activity -->
        <div class="data-card">
          <div class="data-card-header">
            <h3>Recent Activity</h3>
          </div>
          <div class="data-card-body">
            <table class="dash-table">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Action</th>
                  <th>Details</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Admin</td>
                  <td><span class="badge badge-success">CREATE</span></td>
                  <td>Added new student – Arjun Mehta</td>
                  <td>10 min ago</td>
                </tr>
                <tr>
                  <td>Dr. Rajesh Kumar</td>
                  <td><span class="badge badge-primary">UPDATE</span></td>
                  <td>Uploaded Physics Chapter 12 materials</td>
                  <td>25 min ago</td>
                </tr>
                <tr>
                  <td>Admin</td>
                  <td><span class="badge badge-accent">CONFIG</span></td>
                  <td>Updated tenant settings for ENF Academy</td>
                  <td>1 hr ago</td>
                </tr>
                <tr>
                  <td>Mrs. Priya Singh</td>
                  <td><span class="badge badge-success">CREATE</span></td>
                  <td>Created Chemistry Unit Test 4</td>
                  <td>2 hrs ago</td>
                </tr>
                <tr>
                  <td>System</td>
                  <td><span class="badge badge-warning">BACKUP</span></td>
                  <td>Automated daily backup completed</td>
                  <td>6 hrs ago</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="data-card">
          <div class="data-card-header">
            <h3>Quick Actions</h3>
          </div>
          <div class="data-card-body">
            <div class="quick-actions-grid">
              <a href="#" class="quick-action-btn blue">
                <i class="fas fa-user-plus"></i>
                <span>Add Student</span>
              </a>
              <a href="#" class="quick-action-btn green">
                <i class="fas fa-user-plus"></i>
                <span>Add Teacher</span>
              </a>
              <a href="#" class="quick-action-btn amber">
                <i class="fas fa-layer-group"></i>
                <span>Create Batch</span>
              </a>
              <a href="#" class="quick-action-btn purple">
                <i class="fas fa-book"></i>
                <span>Manage Subjects</span>
              </a>
              <a href="#" class="quick-action-btn red">
                <i class="fas fa-clipboard-list"></i>
                <span>View Audit Logs</span>
              </a>
              <a href="/admin/" class="quick-action-btn dark">
                <i class="fas fa-tools"></i>
                <span>Django Admin</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- ── API Endpoints Status ── -->
      <div class="data-card">
        <div class="data-card-header">
          <h3>API Endpoints Status</h3>
        </div>
        <div class="data-card-body">
          <table class="dash-table">
            <thead>
              <tr>
                <th>Endpoint</th>
                <th>Method</th>
                <th>Status</th>
                <th>Avg Response</th>
                <th>Last Checked</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><code>/api/token/</code></td>
                <td><span class="badge badge-primary">POST</span></td>
                <td><span class="badge badge-success">200 OK</span></td>
                <td>45ms</td>
                <td>2 min ago</td>
              </tr>
              <tr>
                <td><code>/api/users/</code></td>
                <td><span class="badge badge-success">GET</span></td>
                <td><span class="badge badge-success">200 OK</span></td>
                <td>120ms</td>
                <td>2 min ago</td>
              </tr>
              <tr>
                <td><code>/api/batches/</code></td>
                <td><span class="badge badge-success">GET</span></td>
                <td><span class="badge badge-success">200 OK</span></td>
                <td>85ms</td>
                <td>2 min ago</td>
              </tr>
              <tr>
                <td><code>/api/tests/</code></td>
                <td><span class="badge badge-success">GET</span></td>
                <td><span class="badge badge-success">200 OK</span></td>
                <td>95ms</td>
                <td>2 min ago</td>
              </tr>
              <tr>
                <td><code>/api/audit-logs/</code></td>
                <td><span class="badge badge-success">GET</span></td>
                <td><span class="badge badge-success">200 OK</span></td>
                <td>150ms</td>
                <td>2 min ago</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </section>
  </main>
</div>
{% endblock %}
