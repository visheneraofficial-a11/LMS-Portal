</section>

<!-- ========== FOOTER ========== -->
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Col 1: Brand -->
      <div class="footer-col">
        <div class="footer-brand">
          <div class="logo-icon">E</div>
          <span>ENABLE PROGRAM</span>
