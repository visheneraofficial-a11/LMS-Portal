      <p style="color:var(--gray-500);font-size:1.125rem;max-width:640px;margin:0 auto">The dedicated professionals managing ENF's programs and operations.</p>
    </div>

    <div class="team-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px">

      <!-- 1. Er. Kanhaiya Singh -->
