        <p>Ex Navodayan Foundation (ENF) is a premier not-for-profit organization dedicated to empowering Navodaya alumni and students through quality education, mentorship, and technology-enabled learning programs across India.</p>
        <div class="footer-social">
          <a href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
          <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="https://twitter.com" target="_blank" rel="noopener" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
          <a href="https://linkedin.com" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
          <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/about/">About Us</a></li>
          <li><a href="/programs/">Programs</a></li>
          <li><a href="/partners/">Partners</a></li>
          <li><a href="/scholarships/">Scholarships</a></li>
          <li><a href="/news/">News</a></li>
          <li><a href="/gallery/">Gallery</a></li>
        </ul>
      </div>

      <!-- Col 3: Programs -->
      <div class="footer-col">
        <h4>Programs</h4>
        <ul class="footer-links">
          <li><a href="/programs/">CoE</a></li>
          <li><a href="/programs/">ENABLE</a></li>
          <li><a href="/programs/">TPDDL</a></li>
          <li><a href="/programs/">ASOSE</a></li>
          <li><a href="/programs/">SEED</a></li>
        </ul>
      </div>

      <!-- Col 4: Get in Touch -->
      <div class="footer-col">
        <h4>Get in Touch</h4>
        <div class="footer-contact">
          <div class="footer-contact-item">
            <i class="fas fa-location-dot"></i>
            <span>B-36/43-46M, Brahmanand Colony, Durgakund, Varanasi, UP (221005)</span>
          </div>
          <div class="footer-contact-item">
            <i class="fas fa-phone"></i>
            <span>+91-76070 02100</span>
          </div>
          <div class="footer-contact-item">
            <i class="fas fa-envelope"></i>
            <span>exnavodayanfoundation1@gmail.com</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p>&copy; 2026 Ex Navodayan Foundation. All rights reserved.</p>
      <p>Design by <a href="https://erpdsoft.com" target="_blank" rel="noopener">ERPDSOFT</a></p>
    </div>
  </div>
</footer>

{% endblock %}

{% block extra_js %}
<script>
  // Navbar scroll effect
  window.addEventListener('scroll', function () {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50);
  });

  // Login Modal
  function openLoginModal() {
    document.getElementById('loginModal').classList.add('show');
  }
  function closeLoginModal() {
    document.getElementById('loginModal').classList.remove('show');
  }
  document.getElementById('loginModal').addEventListener('click', function (e) {
    if (e.target === this) closeLoginModal();
  });

  // Mobile menu toggle
  function toggleMobileMenu() {
    var links = document.getElementById('navLinks');
    links.classList.toggle('show');
  }

  // Intersection Observer for scroll animations
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-aos]').forEach(function (el) {
    observer.observe(el);
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(function (anchor) {
    anchor.addEventListener('click', function (e) {
      var targetId = this.getAttribute('href');
      if (targetId === '#') return;
      e.preventDefault();
      var target = document.querySelector(targetId);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
{% endblock %}
