{% block extra_js %}
<script>
  // Scholarship Tab Switching
  document.querySelectorAll('.scholarship-tab').forEach(tab => {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.scholarship-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.scholarship-list').forEach(l => l.classList.remove('active'));
      this.classList.add('active');
      document.getElementById(this.dataset.target).classList.add('active');
    });
  });

  // Navbar scroll effect
  window.addEventListener('scroll', function () {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50);
  });

  // Login Modal
  function openLoginModal() {
    document.getElementById('loginModal').classList.add('show');
  }
  function closeLoginModal() {
    document.getElementById('loginModal').classList.remove('show');
  }
  document.getElementById('loginModal').addEventListener('click', function (e) {
    if (e.target === this) closeLoginModal();
  });

  // Mobile menu toggle
  function toggleMobileMenu() {
    var links = document.getElementById('navLinks');
    links.classList.toggle('show');
  }

  // Intersection Observer for scroll animations
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-aos]').forEach(function (el) {
    observer.observe(el);
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(function (anchor) {
    anchor.addEventListener('click', function (e) {
      var targetId = this.getAttribute('href');
      if (targetId === '#') return;
      e.preventDefault();
      var target = document.querySelector(targetId);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
{% endblock %}
