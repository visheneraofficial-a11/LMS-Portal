<!-- ========== CTA SECTION ========== -->
<section class="cta-section" data-aos="fade-up">
  <div class="container">
    <h2>Start Your Journey Today</h2>
    <p style="color:rgba(255,255,255,.85);max-width:560px;margin:0 auto 24px">Explore scholarship opportunities and get the financial support you need for your Engineering or Medical studies.</p>
    <div class="cta-buttons">
      <a href="#contact" class="btn btn-primary btn-lg">Get Guidance</a>
      <a href="/programs/" class="btn btn-outline-white btn-lg">Explore Programs</a>
