      </a>

      <a href="/management/" class="content-box" data-aos="fade-up" data-aos-delay="100" style="text-align:center;padding:40px 24px;text-decoration:none;transition:transform .3s,box-shadow .3s">
        <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--primary));display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
          <i class="fas fa-users-cog" style="font-size:1.75rem;color:#fff"></i>
        </div>
        <h3 style="font-size:1.25rem;font-weight:700;color:var(--gray-900);margin-bottom:8px">Management Team</h3>
