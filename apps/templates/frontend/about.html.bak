{% extends 'base.html' %}
{% load static %}

{% block body %}

<!-- ========== NAVBAR ========== -->
<nav class="navbar" id="navbar">
  <div class="container">
    <a href="/" class="nav-brand">
      <div class="logo-icon">E</div>
      <span>ENABLE PROGRAM</span>
    </a>
    <ul class="nav-links" id="navLinks">
      <li><a href="/">Home</a></li>
      <li class="nav-dropdown">
        <a href="#" class="active">About <i class="fas fa-chevron-down" style="font-size:.625rem;margin-left:4px"></i></a>
        <div class="dropdown-menu">
          <a href="/about/" class="active"><i class="fas fa-building"></i> About ENF</a>
          <a href="/founder/"><i class="fas fa-user-tie"></i> Founder &amp; Trustees</a>
          <a href="/management/"><i class="fas fa-users-cog"></i> Management Team</a>
        </div>
      </li>
      <li><a href="/programs/">Programs</a></li>
      <li><a href="/partners/">Partners</a></li>
      <li><a href="/scholarships/">Scholarships</a></li>
      <li><a href="/news/">News</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <div class="nav-actions">
      <a href="javascript:void(0)" class="btn btn-primary btn-sm" onclick="openLoginModal()"><i class="fas fa-sign-in-alt"></i> Login</a>
    </div>
    <button class="mobile-menu-btn" onclick="toggleMobileMenu()"><i class="fas fa-bars"></i></button>
  </div>
</nav>

<!-- ========== LOGIN MODAL ========== -->
<div class="login-modal-overlay" id="loginModal">
  <div class="login-modal" style="position:relative">
    <button class="login-modal-close" onclick="closeLoginModal()"><i class="fas fa-times"></i></button>
    <div class="login-modal-header">
      <h2>Welcome Back</h2>
      <p>Select your role to continue</p>
    </div>
    <div class="login-role-grid">
      <a href="/login/?role=student" class="login-role-card">
        <div class="role-icon student"><i class="fas fa-user-graduate"></i></div>
        <h3>Student</h3>
        <span>Access your classes</span>
      </a>
      <a href="/login/?role=teacher" class="login-role-card">
        <div class="role-icon teacher"><i class="fas fa-chalkboard-teacher"></i></div>
        <h3>Teacher</h3>
        <span>Manage your courses</span>
      </a>
      <a href="/login/?role=admin" class="login-role-card">
        <div class="role-icon admin"><i class="fas fa-user-shield"></i></div>
        <h3>Admin</h3>
        <span>System management</span>
      </a>
    </div>
  </div>
</div>

<!-- ========== PAGE HEADER ========== -->
<section class="page-header">
  <div class="container">
    <h1>About Us</h1>
    <div class="breadcrumb">
      <a href="/">Home</a> <i class="fas fa-chevron-right" style="font-size:.625rem"></i> <span>About Us</span>
    </div>
  </div>
</section>

<!-- ========== ABOUT SECTION ========== -->
<section class="programs-section" data-aos="fade-up">
  <div class="container">
    <div class="about-content" style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center">

      <!-- Left: About Text -->
      <div class="about-text" data-aos="fade-right">
        <h3 style="font-size:1.75rem;font-weight:800;color:var(--gray-900);margin-bottom:16px">Ex Navodayan Foundation (ENF)</h3>
        <p style="color:var(--gray-500);line-height:1.8;margin-bottom:16px">Ex Navodayan Foundation (ENF) was established by JNV Alumni in 2016 and registered as a Trust under the Indian Trust Act. ENF is dedicated to support senior secondary students from underprivileged and marginalized backgrounds and help deserving students to qualify for premier institutes of engineering and medicine.</p>
        <p style="color:var(--gray-500);line-height:1.8">Since its inception, ENF has grown from supporting 50 students to reaching over 15,000 students across 380+ partner schools through programs like CoE, ENABLE, TPDDL, ASOSE, and SEED.</p>
      </div>

      <!-- Right: About Visual -->
      <div class="about-visual" data-aos="fade-left" style="display:flex;align-items:center;justify-content:center">
        <div style="background:linear-gradient(135deg,var(--primary),var(--accent));border-radius:24px;width:100%;height:320px;display:flex;align-items:center;justify-content:center">
          <i class="fas fa-graduation-cap" style="font-size:8rem;color:rgba(255,255,255,.25)"></i>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ========== MISSION & VISION ========== -->
<section class="programs-section" data-aos="fade-up" style="padding-top:0">
  <div class="container">
    <div class="mission-vision-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:32px">

      <!-- Mission Card -->
      <div class="content-box" data-aos="fade-up">
        <h3 style="font-size:1.25rem;font-weight:700;color:var(--gray-900);margin-bottom:12px">
          <i class="fas fa-bullseye" style="color:var(--primary);margin-right:8px"></i> Our Mission
        </h3>
        <p style="color:var(--gray-500);line-height:1.8">Empowering underprivileged students, with quality education and resources, to help them achieve their academic goals.</p>
      </div>

      <!-- Vision Card -->
      <div class="content-box" data-aos="fade-up">
        <h3 style="font-size:1.25rem;font-weight:700;color:var(--gray-900);margin-bottom:12px">
          <i class="fas fa-eye" style="color:var(--accent);margin-right:8px"></i> Our Vision
        </h3>
        <p style="color:var(--gray-500);line-height:1.8">To provide help and guidance to as many eligible but impoverished learners as possible; enabling them to qualify the JEE/NEET exams, and securing admission to esteemed Engineering and Medical institutes like IIT, AIIMS, etc.</p>
      </div>

    </div>
  </div>
</section>

<!-- ========== STATS SECTION ========== -->
<section class="section-gradient" data-aos="fade-up" style="padding:64px 0;background:linear-gradient(135deg,var(--primary),var(--accent));color:#fff;text-align:center">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:32px">

      <div class="stat-item" data-aos="zoom-in">
        <h3 style="font-size:2.5rem;font-weight:800;margin-bottom:8px" data-count="15000" data-suffix="+">0</h3>
        <p style="opacity:.85;font-size:1rem">Students Guided</p>
      </div>

      <div class="stat-item" data-aos="zoom-in" data-aos-delay="100">
        <h3 style="font-size:2.5rem;font-weight:800;margin-bottom:8px" data-count="380" data-suffix="+">0</h3>
        <p style="opacity:.85;font-size:1rem">Partner Schools</p>
      </div>

      <div class="stat-item" data-aos="zoom-in" data-aos-delay="200">
        <h3 style="font-size:2.5rem;font-weight:800;margin-bottom:8px" data-count="6" data-suffix="+">0</h3>
        <p style="opacity:.85;font-size:1rem">Active Programs</p>
      </div>

      <div class="stat-item" data-aos="zoom-in" data-aos-delay="300">
        <h3 style="font-size:2.5rem;font-weight:800;margin-bottom:8px" data-count="8" data-suffix="+">0</h3>
        <p style="opacity:.85;font-size:1rem">Years of Excellence</p>
      </div>

    </div>
  </div>
</section>

<!-- ========== OUR VALUES ========== -->
<section class="programs-section" data-aos="fade-up">
  <div class="container">
    <div class="section-header" style="text-align:center;margin-bottom:48px" data-aos="fade-up">
      <h2 style="font-size:2rem;font-weight:800;color:var(--gray-900);margin-bottom:12px">Our Values</h2>
      <p style="color:var(--gray-500);font-size:1.125rem;max-width:640px;margin:0 auto">The principles that guide everything we do at ENF.</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px">

      <div class="content-box" data-aos="fade-up" style="text-align:center;padding:32px 20px">
        <div style="width:64px;height:64px;border-radius:50%;background:rgba(79,70,229,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
