        </div>
        <h4 style="font-size:1.1rem;font-weight:700;color:var(--gray-900);margin-bottom:8px">Excellence in Education</h4>
      </div>

      <div class="content-box" data-aos="fade-up" data-aos-delay="100" style="text-align:center;padding:32px 20px">
        <div style="width:64px;height:64px;border-radius:50%;background:rgba(16,185,129,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
          <i class="fas fa-hand-holding-heart" style="font-size:1.5rem;color:var(--accent)"></i>
        </div>
        <h4 style="font-size:1.1rem;font-weight:700;color:var(--gray-900);margin-bottom:8px">Inclusive Access</h4>
      </div>

      <div class="content-box" data-aos="fade-up" data-aos-delay="200" style="text-align:center;padding:32px 20px">
        <div style="width:64px;height:64px;border-radius:50%;background:rgba(245,158,11,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
          <i class="fas fa-lightbulb" style="font-size:1.5rem;color:#f59e0b"></i>
        </div>
        <h4 style="font-size:1.1rem;font-weight:700;color:var(--gray-900);margin-bottom:8px">Innovation &amp; Technology</h4>
      </div>

      <div class="content-box" data-aos="fade-up" data-aos-delay="300" style="text-align:center;padding:32px 20px">
        <div style="width:64px;height:64px;border-radius:50%;background:rgba(139,92,246,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px">
          <i class="fas fa-handshake" style="font-size:1.5rem;color:#8b5cf6"></i>
        </div>
        <h4 style="font-size:1.1rem;font-weight:700;color:var(--gray-900);margin-bottom:8px">Community Partnership</h4>
      </div>

    </div>
  </div>
</section>

<!-- ========== LEADERSHIP QUICK LINKS ========== -->
<section class="programs-section" data-aos="fade-up" style="padding-top:0">
  <div class="container">
    <div class="section-header" style="text-align:center;margin-bottom:48px" data-aos="fade-up">
