        <div class="footer-contact">
          <div class="footer-contact-item">
            <i class="fas fa-location-dot"></i>
            <span>B-36/43-46M, Brahmanand Colony, Durgakund, Varanasi, UP (221005)</span>
          </div>
          <div class="footer-contact-item">
            <i class="fas fa-phone"></i>
            <span>+91-76070 02100</span>
          </div>
          <div class="footer-contact-item">
